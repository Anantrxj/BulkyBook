@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}


<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">


            <div class="card shadow border mt-2">


                <div class="card-header bg-primary bg-gradient py-3">
                    <div class="text-center">
                        <h3 class="text-white m-0">
                            Login
                        </h3>
                    </div>
                </div>



                <div class="card-body p-3">


                    <form id="account" method="post">


                        <h4 class="border-bottom pb-2 mb-3 text-secondary text-center">
                            Login to your account
                        </h4>


                        <div asp-validation-summary="ModelOnly"
                             class="text-danger"
                             role="alert">
                        </div>



                        <div class="form-floating mb-2">

                            <input asp-for="Input.Email"
                                   class="form-control"
                                   autocomplete="username"
                                   placeholder="name@example.com" />


                            <label asp-for="Input.Email">
                                Email
                            </label>


                            <span asp-validation-for="Input.Email"
                                  class="text-danger">
                            </span>

                        </div>




                        <div class="form-floating mb-2">

                            <input asp-for="Input.Password"
                                   class="form-control"
                                   autocomplete="current-password"
                                   placeholder="password" />


                            <label asp-for="Input.Password">
                                Password
                            </label>


                            <span asp-validation-for="Input.Password"
                                  class="text-danger">
                            </span>


                        </div>




                        <div class="checkbox mb-2">

                            <label asp-for="Input.RememberMe">

                                <input class="form-check-input"
                                       asp-for="Input.RememberMe" />

                                @Html.DisplayNameFor(m => m.Input.RememberMe)

                            </label>

                        </div>





                        <button id="login-submit"
                                type="submit"
                                class="w-100 btn btn-primary">

                            Login

                        </button>





                        <div class="mt-2 text-center">


                            <p class="mb-1">

                                <a id="forgot-password"
                                   asp-page="./ForgotPassword">

                                    Forgot your password?

                                </a>

                            </p>



                            <p class="mb-1">

                                <a asp-page="./Register"
                                   asp-route-returnUrl="@Model.ReturnUrl">

                                    Register as a new user

                                </a>

                            </p>




                            <p class="mb-1">

                                <a id="resend-confirmation"
                                   asp-page="./ResendEmailConfirmation">

                                    Resend email confirmation

                                </a>

                            </p>


                        </div>


                    </form>


                </div>


            </div>


        </div>
    </div>
</div>




@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}